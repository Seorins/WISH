# =========================
# GMS Anthropic Claude (등대지기 LLM, S14P31E103-558)
# =========================
# 키 미설정 시 Claude 호출 비활성 → 항상 fallback scene 으로 동작 (로컬에서도 부팅 OK).
# dev/prod 에서는 인프라가 환경변수로 실제 키 주입.
GMS_KEY=
GMS_ANTHROPIC_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com/v1
GMS_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GMS_ANTHROPIC_VERSION=2023-06-01
GMS_ANTHROPIC_TIMEOUT_SECONDS=5