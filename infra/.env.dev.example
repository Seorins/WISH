# =========================
# Common
# =========================
TZ=Asia/Seoul
SPRING_PROFILES_ACTIVE=dev

# Optional: override the default backend image tag during deployment
BACKEND_DEV_IMAGE=imgunbread/e103-wish:backend-develop-latest
AI_DEV_IMAGE=imgunbread/e103-wish:ai-develop-latest

# =========================
# PostgreSQL (dev)
# =========================
POSTGRES_DEV_DB=e103_dev_db
POSTGRES_DEV_USER=postgres
POSTGRES_DEV_PASSWORD=change-me-dev-postgres-password

# Backend datasource
DB_URL=jdbc:postgresql://postgres-dev:5432/e103_dev_db
DB_USERNAME=postgres
DB_PASSWORD=change-me-dev-postgres-password
JPA_DDL_AUTO=validate

# =========================
# Redis (dev)
# =========================
REDIS_HOST=redis-dev
REDIS_PORT=6379

# =========================
# JWT / Backend app
# =========================
JWT_SECRET=change-me-dev-jwt-secret-at-least-32-chars
JWT_ACCESS_TTL_SECONDS=3600
JWT_ISSUER=comong

# =========================
# GMS Anthropic Claude (등대지기 LLM, S14P31E103-558)
# =========================
# 운영 키 주입 필수. 빈 값이면 Claude 비활성화 → 항상 fallback scene.
GMS_KEY=change-me-gms-anthropic-api-key
GMS_ANTHROPIC_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com/v1
GMS_ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
GMS_ANTHROPIC_VERSION=2023-06-01
GMS_ANTHROPIC_TIMEOUT_SECONDS=5
