APP_NAME=Comong AI Service
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8001
LOG_LEVEL=INFO
# CORS 허용 출처 목록 (쉼표로 구분). 운영 환경에서는 실제 도메인으로 교체.
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:5500,http://127.0.0.1:5500,http://localhost:5173,http://127.0.0.1:5173

# =========================
# GMS Anthropic Claude (등대지기 자유 대화)
# =========================
GMS_KEY=
GMS_ANTHROPIC_BASE_URL=https://gms.ssafy.io/gmsapi/api.anthropic.com/v1
GMS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
GMS_ANTHROPIC_VERSION=2023-06-01
GMS_ANTHROPIC_TIMEOUT_SECONDS=5
# 자유 대화 전용 모델 (미설정 시 GMS_ANTHROPIC_MODEL 사용)
DIALOGUE_CHAT_MODEL=

# =========================
# GMS OpenAI Whisper (등대지기 STT)
# =========================
GMS_OPENAI_BASE_URL=https://gms.ssafy.io/gmsapi/api.openai.com/v1
WHISPER_MODEL=whisper-1
WHISPER_TIMEOUT_SECONDS=30
WHISPER_LANGUAGE=ko
# Whisper 도메인 힌트 프롬프트 (미설정 시 기본값 사용)
WHISPER_PROMPT=
