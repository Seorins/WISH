          "choices": ["mky_fru_stuck", "mky_fru_angry", "mky_fru_dunno"]
        },
        "mky_fru_02a_relief": {
          "nodeId": "mky_fru_02a_relief",
          "questionText": "답답할 때 너는 뭐 하면 좀 풀려?",
          "npcLines": [
            "코몽이도 답답할 때 나무 위에 올라가서 가지 막 흔들었어.",
            "가지가 좀 미안했지.",
            "답답할 때 너는 뭐 하면 좀 풀려?"
          ],
          "choices": ["mky_fru_pause", "mky_fru_talk", "mky_fru_just_be"]
        },
        "mky_fru_02b_how": {
          "nodeId": "mky_fru_02b_how",
          "questionText": "그 화를 어디다 두면 좋을까?",
          "npcLines": [
            "화나는 거구나. 코몽이도 화날 땐 가슴이 콩콩 뛰어.",
            "그 화를 어디다 두면 좋을까?"
          ],
          "choices": ["mky_fru_angry_pause", "mky_fru_angry_talk", "mky_fru_angry_body"]
        },
        "mky_fru_03_pause": {
          "nodeId": "mky_fru_03_pause",
          "questionText": "멈추는 거 어떻게 할까?",
          "npcLines": [
            "좋아! 멈추는 거 어떻게 할까?"
          ],
          "choices": ["mky_fru_breathe", "mky_fru_close_eyes"]
        },
        "mky_fru_03_talk": {
          "nodeId": "mky_fru_03_talk",
          "questionText": "누구한테 말하고 싶어?",
          "npcLines": [
            "누구한테 말하고 싶어?"
          ],
          "choices": ["mky_fru_tell_mom", "mky_fru_tell_monkey"]
        },
        "mky_fru_03_body": {
          "nodeId": "mky_fru_03_body",
          "questionText": "어떻게 할까?",
          "npcLines": [
            "몸으로! 코몽이 스타일.",
            "어떻게 할까?"
          ],
          "choices": ["mky_fru_shake_light", "mky_fru_lay_down"]
        },
        "mky_fru_02c_now": {
          "nodeId": "mky_fru_02c_now",
          "questionText": "지금은 뭐가 필요해?",
          "npcLines": [
            "답답한지 화나는지 잘 모를 때도 있지. 코몽이도 그래.",
            "지금은 뭐가 필요해?"
          ],
          "choices": ["mky_fru_quiet", "mky_fru_hug", "mky_fru_with_monkey"]
        }
      }
    },

