          "choices": ["mky_inj_fear", "mky_inj_unknown", "mky_inj_unsure"]
        },
        "mky_inj_02a_who": {
          "nodeId": "mky_inj_02a_who",
          "questionText": "너도 손 잡아줄 사람 있어?",
          "npcLines": [
            "주사라니… 코몽이도 주사 무서워서 한 번 의자 밑에 숨었어.",
            "엄마가 와서 손 꼭 잡아주니까 그제서야 나왔지.",
            "너도 손 잡아줄 사람 있어?"
          ],
          "choices": ["mky_inj_mom", "mky_inj_dunno_who", "mky_inj_monkey_holds"]
        },
        "mky_inj_03a1_how": {
          "nodeId": "mky_inj_03a1_how",
          "questionText": "엄마한테 어떻게 말할까?",
          "npcLines": [
            "오케이!",
            "엄마한테 어떻게 말할까?"
          ],
          "choices": ["mky_inj_say_hold", "mky_inj_say_be_near", "mky_inj_just_go"]
        },
        "mky_inj_03a2_offer": {
          "nodeId": "mky_inj_03a2_offer",
          "questionText": "코몽이가 같이 가줄까?",
          "npcLines": [
            "음… 그럼 코몽이가 같이 가줄까?"
          ],
          "choices": ["mky_inj_yes_together", "mky_inj_be_near_me"]
        },
        "mky_inj_03a3_check": {
          "nodeId": "mky_inj_03a3_check",
          "questionText": "어때, 좀 든든해?",
          "npcLines": [
            "코몽이? 좋아!",
            "(꼬리로 손 잡는 흉내) 자, 잡았다!",
            "어때, 좀 든든해?"
          ],
          "choices": ["mky_inj_feel_good", "mky_inj_still_scared"]
        },
        "mky_inj_02b_ask": {
          "nodeId": "mky_inj_02b_ask",
          "questionText": "누구한테 물어볼 수 있어?",
          "npcLines": [
            "아아, 모르는 게 제일 무섭지.",
            "코몽이도 새 거 할 때 머리가 빙글빙글해.",
            "누구한테 물어볼 수 있어?"
          ],
          "choices": ["mky_inj_ask_teacher", "mky_inj_ask_mom", "mky_inj_not_ask"]
        },
        "mky_inj_02c_now": {
          "nodeId": "mky_inj_02c_now",
          "questionText": "지금은 뭐 하고 싶어?",
          "npcLines": [
            "음… 잘 모르는 마음도 있지. 코몽이도 그래.",
            "지금은 뭐 하고 싶어?"
          ],
          "choices": ["mky_inj_with_monkey", "mky_inj_stay_still", "mky_inj_other_friend"]
        }
      }
